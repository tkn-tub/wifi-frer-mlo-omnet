version 3
run Mobility-1-20260407-11:37:07-23856
attr configname Mobility
attr datetime 20260407-11:37:07
attr datetimef 20260407-113707
attr experiment Mobility
attr inifile omnetpp.ini
attr iterationvars "$speed=9.0, $packetLength=1000, $bitrate=52"
attr iterationvarsd speed=9.0/packetLength=1000/bitrate=52
attr iterationvarsf speed=9.0,packetLength=1000,bitrate=52-
attr measurement "$speed=9.0, $packetLength=1000, $bitrate=52"
attr network MixedNetwork
attr processid 23856
attr repetition 0
attr replication #0
attr resultdir results
attr runnumber 1
attr seedset 1
itervar bitrate 52
itervar packetLength 1000
itervar speed 9.0
config image-path ../../inet4.5/images;../../mlo/images
config extends FRER
config network MixedNetwork
config MixedNetwork.networkSize 16
config *.sta*.mobility.typename RandomWaypointMobility
config *.slo*.mobility.typename RandomWaypointMobility
config *.sta*.mobility.initFromDisplayString false
config *.slo*.mobility.initFromDisplayString false
config *.**.mobility.initialX "uniform(150m, 450m)"
config *.**.mobility.initialY "uniform(100m, 400m)"
config *.**.mobility.initialZ 0m
config *.**.mobility.constraintAreaMinX 0m
config *.**.mobility.constraintAreaMinY 0m
config *.**.mobility.constraintAreaMinZ 0m
config *.**.mobility.constraintAreaMaxX 450m
config *.**.mobility.constraintAreaMaxY 450m
config *.**.mobility.constraintAreaMaxZ 0m
config *.**.speed 9.0mps
config *.sta1.app[0].startTime "uniform(1s, 2s)"
config *.sta1.app[0].sendInterval "exponential(1028 * 8 / 52 * 3.5us * 12)"
config *.slo_sender_sta[*].app[0].messageLength 1000B
config *.slo_sender_sta[*].app[0].startTime "uniform(1s, 2s)"
config *.slo_sender_sta[*].app[0].stopTime 11s
config *.slo_sender_sta[*].app[0].sendInterval "exponential(1028 * 8 / 52 * 3.5us * 12)"
config *.slo_receiver_sta[*].numApps 1
config *.slo_receiver_sta[*].app[0].typename UdpSink
config *.slo_receiver_sta[*].app[0].localPort 5001
config extends SLO
config description "Enables FRER over MLO"
config *.**.classifier.ipProtocolUpMap "\"\""
config *.**.classifier.udpPortUpMap "\"5000 BE\""
config *.**.classifier.tcpPortUpMap "\"\""
config *.**.ieee8021r.protocol.rTagHeaderInserter.nextProtocol "\"ieee80211be\""
config *.**.umac.forwardingTable "{streamA1: \"lmac0\", streamA2: \"lmac1\"}"
config *.**.ieee8021r.policy.streamIdentifier.identifier.mapping "[{stream: \"streamA\", packetFilter: expr(udp.destPort == 5000), sequenceNumbering: true}]"
config *.**.ieee8021r.policy.streamRelay.splitter.mapping "{streamA: [\"streamA1\", \"streamA2\"]}"
config *.**.ieee8021r.policy.streamCoder.decoder.mapping "[{stream: \"streamA1\", interface: \"lmac0\", destination: \"sta2\"}, {stream: \"streamA2\", interface: \"lmac1\", destination: \"sta2\"}]"
config *.**.ieee8021r.policy.streamRelay.merger.mapping "{streamA1: \"streamA\", streamA2: \"streamA\"}"
config *.**.ieee8021r.policy.streamRelay.merger.bufferSize 10000
config *.sta2.ieee8021r.policy.streamRelay.merger.mapping "{streamA1: \"\", streamA2: \"\"}"
config extends General
config description "Initiates UDP traffic over a single (default 2.4 GHz) interface"
config *.sta1.numApps 1
config *.sta1.app[0].typename UdpBasicApp
config *.sta1.app[0].destAddresses "\"sta2\""
config *.sta1.app[0].localPort 5000
config *.sta1.app[0].destPort 5000
config *.sta1.app[0].packetName "\"UDPData:0\""
config *.sta1.app[0].messageLength 1000B
config *.sta1.app[0].sendInterval "exponential(1028 * 8 / 52 * 3.5us)"
config *.sta1.app[0].startTime 1s
config *.sta1.app[0].stopTime 11s
config *.sta2.numApps 1
config *.sta2.app[0].typename UdpSink
config *.sta2.app[0].localPort 5000
config network BaseNetwork
config description "Default configuration for a small MLO-FRER example"
config sim-time-limit 15s
config record-eventlog false
config repeat 1
config **.vector-recording false
config seed-0-mt "0 + 123752"
config **.printPkDetail false
config **.hasStatus true
config **.crcMode "\"computed\""
config **.fcsMode "\"computed\""
config **.numMediumVisualizers 4
config **.displaySignals true
config *.visualizer.mediumVisualizer[0].nodeFilter "\"sta1\""
config *.visualizer.mediumVisualizer[0].signalColor "\"red\""
config *.visualizer.mediumVisualizer[1].nodeFilter "\"sta2\""
config *.visualizer.mediumVisualizer[1].signalColor "\"blue\""
config *.visualizer.mediumVisualizer[2].nodeFilter "\"ap\""
config *.visualizer.mediumVisualizer[2].interfaceFilter "\"wlan[0]\""
config *.visualizer.mediumVisualizer[2].signalColor "\"yellow\""
config *.visualizer.numDataLinkVisualizers 2
config *.visualizer.dataLinkVisualizer[*].displayLinks true
config *.visualizer.dataLinkVisualizer[*].activityLevel "\"peer\""
config *.visualizer.dataLinkVisualizer[0].nodeFilter "\"sta1 or ap\""
config *.visualizer.dataLinkVisualizer[0].lineColor "\"red\""
config *.visualizer.dataLinkVisualizer[0].labelColor "\"red\""
config *.visualizer.dataLinkVisualizer[1].nodeFilter "\"ap or sta2\""
config *.visualizer.dataLinkVisualizer[1].lineColor "\"darkblue\""
config *.visualizer.dataLinkVisualizer[1].labelColor "\"darkblue\""
config *.visualizer.ieee80211Visualizer[0].displayAssociations true
config *.ap.lmac[0].mgmt.ssid "\"wlan2.4\""
config *.ap.lmac[1].mgmt.ssid "\"wlan5\""
config *.*sta*.lmac[0].agent.defaultSsid "\"wlan2.4\""
config *.*sta*.lmac[1].agent.defaultSsid "\"wlan5\""
config *.radioMedium.pathLoss.typename LogNormalShadowing
config *.radioMedium.pathLoss.sigma 2
config **.arp.typename GlobalArp
config *.**.numWlanInterfaces 2
config *.**.lmac[*].protocol "\"ieee80211be\""
config *.**.lmac[*].radio.antenna.numAntennas 2
config *.**.lmac[0].radio.bandwidth 20MHz
config *.**.lmac[1].radio.bandwidth 20MHz
config *.**.lmac[*].radio.receiver.modulation "\"QAM-64\""
config *.**.lmac[*].**.pendingQueue.packetCapacity 100000
config *.**.lmac[0].radio.bandName "\"2.4 GHz\""
config *.**.lmac[1].radio.bandName "\"5 GHz (20 MHz)\""
config *.**.lmac[0].bitrate 52Mbps
config *.**.lmac[1].bitrate 130Mbps
config *.**.umac.defaultInterface "\"lmac0\""
config *.**.lmac[*].mac.hcf.isBlockAckSupported true
config **.hcf.originatorMacDataService.fragmentationPolicy.fragmentationThreshold 10000B
config **.hcf.originatorMacDataService.msduAggregationPolicy.aggregationLengthThreshold 10000
config *.**.mobility.initialX "uniform(270m, 330m)"
config *.**.mobility.initialY "uniform(270m, 330m)"
config *.**.mobility.initialZ 0m
config *.**.**.edcaf[*].recoveryProcedure.shortRetryLimit 3
config *.**.**.edcaf[*].recoveryProcedure.longRetryLimit 3
config *.radioMedium.backgroundNoise.power -110dBm

